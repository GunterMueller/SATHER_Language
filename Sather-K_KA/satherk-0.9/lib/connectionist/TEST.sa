--* FUNCTION: Run all tests of the connectionist classes.
--*
--* CLASSES: CONNECTIONIST_CLASSES_TEST
--* 
--* REQUIRED FILES: connectionist/*.sa
--*
--* RELATED FILES:
--*
--* HISTORY:
--* Last edited: Mar 22 23:51 1992 (hws)
--* Created: Tue May 28 19:47:05 1991 (hws)
--*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

class CONN_TEST is
   -- This puts tests of all the connectionist classes into a
   -- single program. If output of this program is redirected to
   -- a file, only a summary of whether each class passed or did
   -- not pass its tests will be seen. See
   -- "sather/etc/test/connectionist_test.sather" for an appropriate
   -- ".sather" file to use.

   main is
      -- Run all tests of the connectionist classes.
      FEED_FORWARD_NET_TEST::main;
      BACK_PROP_TEST::main;
   end; -- main

end; -- CONN_TEST

--*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
