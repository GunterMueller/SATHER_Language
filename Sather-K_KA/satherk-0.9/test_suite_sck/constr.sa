-- -*- Mode: Sather;  -*-
-- File: constructor.sa
class CONSTR is
   --
   main is
      --
      a:LIST[*](INT):=#LIST[*](INT){5,4,3,6,1,9,1,2,3,4,5,size:=5};

      OUT::i(a.asize0).nl;
      i:INT :=0; until i = a.size loop
	 OUT::i(a[i]).c(' ');
	 i := i+1;
      end; -- loop
      OUT::nl;
      t:TREE(INT):={{{
                             {val:=1},
			                   2,
			     {val:=3}},
		                               4,
		            {{val:=5},
		                           6,
		             {val:=7}}},
		                                   8,
		           {{{val:=9},
		                          10,
		             {val:=11}},
		                              12,
			    {{val:=13},
		                          14,
		            {val:=15}}}};      

      loop OUT::i(t.prefix!).      c(' '); end; OUT::nl;
      loop OUT::i(t.breitensuche!).c(' '); end; OUT::nl;
   end; -- main
end; -- class CONSTRUCTOR

--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
   
class TREE(T) is
   
   left:SAME; val:T; right:SAME;
   
   stream prefix:T is
      if self = void then return; end;
      res := val; resume;
      loop res:=left. prefix!; resume; end;
      loop res:=right.prefix!; resume; end;
   end;

   stream breitensuche:T is
      next:SAME;
      todo:QUEUE(SAME):=QUEUE(SAME)::create;;
      if self = void then return end;
      todo.insert_bottom(self);
      until todo.is_empty loop
	 next:=todo.pop_top;
	 if next.left  /= void then todo.insert_bottom(next.left);  end;
	 if next.right /= void then todo.insert_bottom(next.right); end;
	 res:=next.val;
	 resume;
      end;
   end;
end;

