class BINTREE_LINKED is

  main is

    a: INT;
    b: BOOL;
    q:BINARY_TREE__LINKED(INT);
    r:BINARY_TREE__LINKED(INT);
    s:BINARY_TREE__LINKED(INT);

    -- testing copy_structure and preorder_insert
    q := BINARY_TREE__LINKED(INT)::create;
    r := BINARY_TREE__LINKED(INT)::create;
    r := r.node(1, q).ins_left_leaf(2).left.ins_left_leaf(4).root.\
	   ins_right_leaf(3).right.ins_right_leaf(5);
    OUT::s("Testing copy_structure and preorder_insert:").nl.nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("r:").nl;
    OUT::s(r.str).nl.nl;
    OUT::s("Now r will be copied to s by copy_structure.").nl;
    OUT::s("copy_structure uses preorder_insert to do his job.").nl.nl;
    q := r.copy_structure;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("r:").nl;
    OUT::s(r.str).nl.nl.nl;

    -- testing node
    q := BINARY_TREE__LINKED(INT)::create;
    r := BINARY_TREE__LINKED(INT)::create;
    q := q.node(1, r).ins_left_leaf(2).ins_left_leaf(3);
    OUT::s("Testing node:").nl.nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new root will be inserted in q").nl.nl;
    q := q.node(5, r);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl.nl;

    -- testing node_left and node_right
    q := BINARY_TREE__LINKED(INT)::create;
    r := BINARY_TREE__LINKED(INT)::create;
    OUT::s("Testing node_left and node_right:").nl.nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("r:").nl;
    OUT::s(r.str).nl.nl;
    OUT::s("Now a new node will be inserted in empty trees").nl;
    OUT::s("in q by.node_left and in r by node right.").nl.nl;
    q := q.node_left(1);
    r := r.node_right(2);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("r:").nl;
    OUT::s(r.str).nl.nl;
    OUT::s("Now a new node will be inserted at root by node_left.").nl.nl;
    q := q.node_left(3);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new node will be inserted at root by node_right.").nl.nl;
    q := q.root.node_right(4);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new node will be inserted as left son of the").nl;
    OUT::s("root by node_left.").nl.nl;
    q := q.root.left.node_left(6);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new node will be inserted as right son of the").nl;
    OUT::s("root by node_left.").nl.nl;
    q := q.root.right.node_left(7);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new node will be inserted as left son of the").nl;
    OUT::s("root by node_right.").nl.nl;
    q := q.root.left.node_right(8);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new node will be inserted as right son of the").nl;
    OUT::s("root by node_right.").nl.nl;
    q := q.root.right.node_right(9);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl.nl;

    -- testing ins_left_leaf and ins_right_leaf
    q := BINARY_TREE__LINKED(INT)::create;
    r := BINARY_TREE__LINKED(INT)::create;
    q := q.node(1, r);
    OUT::s("Testing ins_left_leaf and ins_right_leaf:").nl.nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    q := q.ins_left_leaf(2);
    OUT::s("Now ins_left_leaf and ins_right_leaf on root where").nl;
    OUT::s("the corresponding subtree is empty.").nl.nl;
    q := q.ins_left_leaf(2);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    q := q.ins_right_leaf(3);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now ins_left_leaf and ins_right_leaf on root where").nl;
    OUT::s("the corresponding subtree is not empty.").nl.nl;
    begin
      q := q.ins_left_leaf(4);
      except not_empty_left
      when EXCEPTION__BINARY_TREE then OUT::s(not_empty_left.str).nl;
    end;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    begin
      q := q.ins_right_leaf(3);
      except not_empty_right
      when EXCEPTION__BINARY_TREE then OUT::s(not_empty_right.str).nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;

    -- testing ins_left_tree and ins_right_tree
    q := BINARY_TREE__LINKED(INT)::create;
    r := BINARY_TREE__LINKED(INT)::create;
    s := BINARY_TREE__LINKED(INT)::create;
    q := q.node(1, s);
    r := r.node(2, s);
    OUT::s("Testing ins_left_tree and ins_right_tree:").nl.nl;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("r:").nl;
    OUT::s(r.str).nl.nl;
    q := q.ins_left_leaf(2);
    OUT::s("Now r will be inserted with ins_left_tree in q").nl.nl;
    q := q.ins_left_tree(r);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new r will be inserted with ins_right_tree in q").nl.nl;
    r := BINARY_TREE__LINKED(INT)::create.node(3, s);
    q := q.ins_right_tree(r);
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new r will be inserted with ins_left_tree in q").nl;
    OUT::s("where the left subtree is not empty").nl.nl;
    r := BINARY_TREE__LINKED(INT)::create.node(4, s);
    begin
      q := q.root.ins_left_tree(r);
      except not_empty_left
      when EXCEPTION__BINARY_TREE then OUT::s(not_empty_left.str).nl;
    end;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;
    OUT::s("Now a new r will be inserted with ins_right_tree in q").nl;
    OUT::s("where the right subtree is not empty").nl.nl;
    r := BINARY_TREE__LINKED(INT)::create.node(5, s);
    begin
      q := q.root.ins_right_tree(r);
      except not_empty_right
      when EXCEPTION__BINARY_TREE then OUT::s(not_empty_right.str).nl;
    end;
    OUT::s("q:").nl;
    OUT::s(q.str).nl.nl;

-- testing delete_right not_empty, exceptions would be tested later
q_t:$BINARY_TREE_LINKED(INT);
removed:$BINARY_TREE_LINKED(INT);

q_t:=node(1,nil).ins_left_leaf(2).left.ins_left_leaf(4).left.\
     ins_left_leaf(6).ins_right_leaf(7).root.\
     ins_right_leaf(3).right.ins_right_leaf(5).right.\
     ins_left_leaf(8).ins_right_leaf(9);

-- testing case act_pos is the left son of his father and
--    at the same time his right son are empty
   OUT::s("Tree bevor beginning delete_left :").nl;
   OUT::s(q_t.root.left.str).nl;
   OUT::s("Tree after delete_left,").nl;
   OUT::s("the act_pos is moved to father as the right son was empty"); 
   OUT::s(q_t.delete_left(removed).str).nl;
   OUT::s("Removed part of tree are now a new object:").nl;
   OUT::s(removed.str).nl;


-- testing case act_pos is the right son of his father and
--    at the same time his left son are empty
   OUT::s("Tree bevor beginning delete_right :").nl;
   OUT::s(q_t.root.right.str).nl;
   OUT::s("Tree after delete_right,").nl;
   OUT::s("the act_pos is moved to father as the left son was empty"); 
   OUT::s(q_t.delete_right(removed).str).nl;
   OUT::s("Removed part of tree are now a new object:").nl;
   OUT::s(removed.str).nl;


-- testing delete_right not_empty, exceptions would be tested later
r_t:$BINARY_TREE_LINKED(INT);
r_t:=node(1,nil).ins_left_leaf(2).left.ins_right_leaf(4).right.\
     ins_left_leaf(6).ins_right_leaf(7).root.\
     ins_right_leaf(3).right.ins_left_leaf(5).left.\
     ins_left_leaf(8).ins_right_leaf(9);

-- testing case act_pos is the left son of his father and
--    at the same time his left son are empty
   OUT::s("Tree bevor beginning delete_right :").nl;
   OUT::s(q_t.root.left.str).nl;
   OUT::s("Tree after delete_right,").nl;
   OUT::s("the act_pos is moved to father as the left son was empty"); 
   OUT::s(q_t.delete_right(removed).str).nl;
   OUT::s("Removed part of tree are now a new object:").nl;
   OUT::s(removed.str).nl;

-- testing case act_pos is the right son of his father and
--    at the same time his right son are empty
   OUT::s("Tree bevor beginning delete_right :").nl;
   OUT::s(q_t.root.right.str).nl;
   OUT::s("Tree after delete_right,").nl;
   OUT::s("the act_pos is moved to father as the right son was empty"); 
   OUT::s(q_t.delete_right(removed).str).nl;
   OUT::s("Removed part of tree are now a new object:").nl;
   OUT::s(removed.str).nl;
  end;


  -- testing empty
    OUT::s("The tree is empty, empty is TRUE").nl;
    b := q.empty;
    OUT::b(b).nl;
      
    q := q.node_right(1);
    q := q.node_left(2);
    q := q.father.node_right(3);
    q := q.node_left(4);
    q := q.father.node_right(5);
    OUT::s("The tree q is now not empty, empty is FALSE").nl;
    b := q.empty;
    OUT::b(b).nl;
  
   -- testing empty_left and empty_right
    OUT::s("The actual_position in tree q is leaf, empty_left = TRUE").nl;
    b := q.empty_left;
    OUT::b(b).nl;
    OUT::s("                                       empty_right= TRUE").nl;
    b := q.empty_right;
    OUT::b(b).nl;
    
    OUT::s("The actual_position in tree q has subtrees, at_leaf = FALSE").nl;
    b := q.father.at_leaf;
    OUT::b(b).nl;

  
  -- testing at root
    OUT::s("The actual_position in tree q has father, at_root = FALSE").nl;
    b := q.at_root;
    OUT::b(b).nl;
  
  -- testing content 
    OUT::s("The content at actual position is 5").nl;
    a := q.content;
    OUT::i(a).nl;
    
  -- testing father
    OUT::s("The content at father of actual position is 3").nl;
    a := q.father.content;
    OUT::i(a).nl;

  -- testing left
    OUT::s("The content in node in root in left subtree of actual position is 4").nl;
    a := q.left.content;
    OUT::i(a).nl;
  
  -- testing right
    OUT::s("The content in node in root in right subtree of actual position is 5").nl;
    a := q.father.right.content;
    OUT::i(a).nl;

  -- testing root
    OUT::s("The content in node at root is 1").nl;
    a := q.root.content;
    OUT::i(a).nl;
  
  -- testing delete_right_tree
    OUT::s("The content in node at right subtree is 5 now").nl;
    a := q.root.right.right.content; 
    OUT::i(a).nl;      q:= q.father;
    OUT::s("The right subtree  is empty now (empty_right =TRUE)").nl;
    b := q.empty_right;
    OUT::b(b).nl;
  
  -- testing delete_left_tree
    OUT::s("The content in node at left subtree is 4 now").nl;
    a := q.root.right.left.content; 
    OUT::i(a).nl;      q:= q.father;
    OUT::s("The left subtree  is empty now (empty_left =TRUE)").nl;
    b := q.empty_left;
    OUT::b(b).nl;


  -- testing exceptions in empty tree in empty_right, empty_left, at_leaf, 
  --			   at_root,content,father,left,right,root
  --			   delete_right_tree,delete_left_tree
  --			   delete_right,delete_left

    begin
    OUT::s("The tree r is empty, empty_left raises an exception").nl;
    b := r.empty_left;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;
   
    begin 
    OUT::s("The tree r is empty, empty_right raises an exception").nl;
    b := r.empty_right;
    except empty_right_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_right_tree.str).nl;
    end;
 
    begin
    OUT::s("The tree r is empty, at_leaf raises an exception").nl;
    b := r.at_leaf;
    except empty_at_leaf
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_at_leaf.str).nl;
    end;
    
    begin
    OUT::s("The tree r is empty, at_root raises an exception").nl;
    b := r.at_root;
    except empty_at_root
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_at_root.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, content raises an exception").nl;
    a := r.content;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, father raises an exception").nl;
    r := r.father;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, left raises an exception").nl;
    r := r.left;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, right raises an exception").nl;
    r := r.right;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, root raises an exception").nl;
    r := r.root;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, delete_right, delete_right_tree raises an exception").nl;
    r := r.delete_right(:s);
    r := r.delete_right_tree;
    except empty_right_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_right_tree.str).nl;
    end;

    begin
    OUT::s("The tree r is empty, delete_left, delete_left_tree raises an exception").nl;
    r := r.delete_left(:s);
    r := r.delete_left_tree;
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;

  -- testing exceptions in delete_right_tree,delete_left_tree
  --			   delete_right,delete_left if the
  --			   according nodes are empty
    begin
    OUT::s("The leaf in tree r has no subtrees, delete functions (left,right, right_tree, left_tree) raise an exception").nl;
    q := q.root.left;
    q := q.delete_right_tree;
    q := q.delete_left_tree;
    q := q.delete_right(:s);
    q := q.delete_left(:s);
    except empty_left_tree
    when EXCEPTION__BINARY_TREE then  OUT::s(empty_left_tree.str).nl;
    end;
  end; -- main

  end; -- TEST__BINARY_TREE__LINKED


