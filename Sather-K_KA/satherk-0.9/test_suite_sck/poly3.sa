class POLY3 is

   main is
      list:LIST[*]($LIVING);
      human_list:LIST[*](HUMAN):=#LIST[2](HUMAN);
      cat:LIVING:=LIVING::new;
      human:HUMAN;
      
      --list:=human_list;
      list:=list.new(5).push(cat);
      human := list.pop;
      human.x;
   end;
   
end; -- class POLY3

--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
class LIVING is
end;
class HUMAN  is
   subtype of LIVING;
   y:INT;
   x is
      y:=5;
   end;
end;
