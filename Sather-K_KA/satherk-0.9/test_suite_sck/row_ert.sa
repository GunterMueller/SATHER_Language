--* Last edited: Nov 29 15:38 1993 (holzw)
--
-- tests for ROW and ARR classes
-- run time errors
--

class ROW_OK is

   main is
      a:ROW[5](CHAR);
      b:ROW[10](INT);
      c:ARR[*];
      d:ARR[2];
      e:ARR[3];
      f:ARR[3-1];
      i,sum: INT;

      ---------------------------------- assignments between arrs
      c:= d;
      c:= f;
      d:= f;
      d:= e; -- error: ARR[2] <-> ARR[3]
      f:= d;
      f:= c;


      ---------------------------------- test row asize attribuet
      OUT::s("size check: ");
      if a.asize*2=b.asize then
	OUT::s("OK.").nl;
      else
	OUT::s("failed.").nl;
      end;

      ---------------------------------- test row element access
      OUT::s("row element access: ");
      a[0]:= 10;
      i:= 1;
      while i<5 loop
	a[i]:= i;
	i:= i+1;
      end;

      i:= 1;
      sum:= 0;
      while i<5 loop
	sum:= sum+ a[i];
	i:= i+1;
      end;

      if a[0]=sum then
	OUT::s("OK.").nl;
      else
	OUT::s("failed.").nl;
      end;

      ---------------------------------- test arr element access
      OUT::s("size check: ");
      if a.asize*2=b.asize then
	OUT::s("OK.").nl;
      else
	OUT::s("failed.").nl;
      end;

   end;
end;
