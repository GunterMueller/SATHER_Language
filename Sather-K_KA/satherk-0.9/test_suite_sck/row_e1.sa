--
-- tests for ROW and ARR classes
-- errors found by semantic analysis
--

class ROW_OK is

   main is
      a:ROW[5](CHAR);
      b:ROW[10](INT);
      c:ARR[*];
      d:ARR[2];
      e:ARR[3];
      f:ARR[3-1];
      i,sum: INT;

      ---------------------------------- write to asize;
      a.asize:= a.asize+1;
      c.asize:= a.asize;
      i:= ROW[*]::asize;
      i:= ARR[*]::asize;

      ---------------------------------- test row element access
      OUT::s("row element access: ");
      a[0]:= 10;
      i:= 1;
      while i<5 loop
	a[i]:= i;
	i:= i+1;
      end;

      i:= 1;
      sum:= 0;
      while i<5 loop
	sum:= sum+ a[i];
	i:= i+1;
      end;

      if a[0]=sum then
	OUT::s("OK.").nl;
      else
	OUT::s("failed.").nl;
      end;

      ---------------------------------- test arr element access
      -- ...

   end;
end;
