  str:STR is
    res := "(".s("key = ").s(key.str).s(",").s("val = ").s(val.str).s(")");
  end;
  
  is_equal(x:PARTIAL_STR):BOOL is
     -- * METHOD: is_equal(x:PARTIAL_STR):BOOL
     -- * DESCRIPTION: self=x
     -- * PRE: true
     -- * POST: key=x.key
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := x.key=key
  end;

end;

--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

value class FINITE_PARTIAL_INT is
  -- * CLASS: FINITE_PARTIAL_INT
  -- * DESCRIPTION: example of a finite type over integers with \
  -- * partial key access
  -- * SUBCLASS OF:
  -- * SPECIALIZATION OF:
  -- * IMPLEMENTATION OF:
  -- * EXCEPTIONS:
  -- * INVARIANT: map[i]<map[j] IFF i<j AND key=map[elt].key AND val=map[elt].val AND \
  -- * elt=key AND (x<y IFF x.elt < y.elt)
  -- * REPRESENTATION:
  -- * COMPLEXITY: O(n)
  -- * REFERENCES:
  -- * ATTRIBUTES: const n :INT := 100; \
  -- * const map:ARR[10](INT) :=  #ARR[100](PARTIAL_INT){...}\
  -- * elt:INT; \
  -- * key:INT; \
  -- * val:INT;
  const n:INT := 100;
  const map:ARR[*](PARTIAL_INT) := create;

  elt:INT;

  create:ARR[*](PARTIAL_INT) is
    i:INT;
    res := #ARR[n](PARTIAL_INT);
    loop
      i:=0.upto!(n-1);
      res[i] := #PARTIAL_INT{key:=i,val:=i};
    end;
  end;

  init:SAME is
     -- * METHOD: init:SAME
     -- * DESCRIPTION: sets val to key
     -- * PRE: NOT self=void 
     -- * POST: res=self' AND val=map[elt].val AND key=elt
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := self;
  end;

  set_key(k:INT) is
    elt:=k;
  end;

  set_val(v:INT) is
    elt:=v;
  end;

  key:INT is
    res := map[elt].key;
  end;

  val:INT is
    res := map[elt].val;
  end;

  is_equal(x:FINITE_PARTIAL_INT):BOOL is
     -- * METHOD: is_equal(x:PARTIAL_INT):BOOL
     -- * DESCRIPTION: self=x
     -- * PRE: true
     -- * POST: elt=x.elt
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := x.elt=elt
  end;

  is_lt(x:FINITE_PARTIAL_INT):BOOL is
     -- * METHOD: is_lt(x:FINITE_PARTIAL_INT):BOOL
     -- * DESCRIPTION: self < x 
     -- * PRE: true
     -- * POST: res = key<x.key
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := key<x.key;
  end;

  is_leq(x:FINITE_PARTIAL_INT):BOOL is
     -- * METHOD: is_leq(x:FINITE_PARTIAL_INT):BOOL
     -- * DESCRIPTION: self <= x 
     -- * PRE: true
     -- * POST: res = key<=x.key
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := key<=x.key;
  end;

  is_gt(x:FINITE_PARTIAL_INT):BOOL is
     -- * METHOD: is_gt(x:FINITE_PARTIAL_INT):BOOL
     -- * DESCRIPTION: self > x 
     -- * PRE: true
     -- * POST: res = key>x.key
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := key>x.key;
  end;

  is_geq(x:FINITE_PARTIAL_INT):BOOL is
     -- * METHOD: is_geq(x:FINITE_PARTIAL_INT):BOOL
     -- * DESCRIPTION: self >= x 
     -- * PRE: true
     -- * POST: res = key>=x.key
     -- * COMPLEXITY: O(1)
     -- * REFERENCES:
    res := key>=x.key;
  end;

  str:STR is
    res := map[elt].str;
  end;

end;


