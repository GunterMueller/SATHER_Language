       res := d_subset.subset(s,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
  end; -- subset



  copy_set:SAME is
    -- * METHOD:copy_set:SAME
    -- * DESCRIPTION: abstract method copying a set
    -- * PRE: true
    -- * POST: (FORALL x:T:res.member(x) IFF member(x)) AND res.size=sizeAND self'=self AND\
    -- * res=d_copy_set.copy_set(repr)
    -- * COMPLEXITY: \
    -- * SIZE__copy_set(self.SIZE) = $COPY_SET__SET__I(T,KERNEL)::SIZE__copy_set(self.SIZE) \
    -- * SPACE__copy_set(self.SIZE) = $COPY_SET__SET__I(T,KERNEL)::SPACE__copy_set(self.SIZE) \
