    -- * SPACE__add(self.SIZE,t.SIZE) = $ADD__SET__I(T,KERNEL)::SPACE__add(self.SIZE,t.SIZE) \
    -- * TIME__add(self.SIZE,t.SIZE) = $ADD__SET__I(T,KERNEL)::TIME__add(self.SIZE,t.SIZE)
    -- * REFERENCES:

    begin
       repr := d_add.add(t,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- add



  multiplicity(x:T):INT is
    -- * METHOD:multiplicity(x:T):INT
    -- * DESCRIPTION: computes the multiplicity of x in self
    -- * PRE: true
    -- * POST: (res=1 IFF member(x)) AND (res=0 IFF NOT member(x)) AND\
    -- * res=d_multiplicity.multiplicity(x,repr)
    -- * COMPLEXITY: \
    -- * SIZE__multiplicity(self.SIZE,x.SIZE) = $MULTIPLICITY__SET__I(T,KERNEL)::SIZE__multiplicity(self.SIZE,x.SIZE) \
    -- * SPACE__multiplicity(self.SIZE,x.SIZE) = $MULTIPLICITY__SET__I(T,KERNEL)::SPACE__multiplicity(self.SIZE,x.SIZE) \
    -- * TIME__multiplicity(self.SIZE,x.SIZE) = $MULTIPLICITY__SET__I(T,KERNEL)::TIME__multiplicity(self.SIZE,x.SIZE)
    -- * REFERENCES:

    begin
       res := d_multiplicity.multiplicity(x,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
  end; -- multiplicity



  disjoint_union(s:$SET(T)):SAME is
    -- * METHOD:disjoint_union(s:$SET(T)):SAME
    -- * DESCRIPTION: abstract method for disjoint union of self and s
    -- * PRE:  FORALL x:T: member(x) IMPLIES NOT s.member(x) 
    -- * POST:  FORALL x:T: res.multiplicity(x)  = multiplicity(x) + s.multiplicity(x) AND \
    -- * res.size = size+s.size AND\
    -- * res=d_disjoint_union.disjoint_union(s,repr)
    -- * COMPLEXITY: \
    -- * SIZE__disjoint_union(self.SIZE,s.SIZE) = $DISJOINT_UNION__SET__I(T,KERNEL)::SIZE__disjoint_union(self.SIZE,s.SIZE) \
    -- * SPACE__disjoint_union(self.SIZE,s.SIZE) = $DISJOINT_UNION__SET__I(T,KERNEL)::SPACE__disjoint_union(self.SIZE,s.SIZE) \
    -- * TIME__disjoint_union(self.SIZE,s.SIZE) = $DISJOINT_UNION__SET__I(T,KERNEL)::TIME__disjoint_union(self.SIZE,s.SIZE)
    -- * REFERENCES:

    begin
       repr := d_disjoint_union.disjoint_union(s,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- disjoint_union



  union(s:$SET(T)):SAME is
    -- * METHOD:union(s:$SET(T)):SAME
    -- * DESCRIPTION: abstract method for union of self and s
    -- * PRE:   true
    -- * POST:  (FORALL x:T: member(x) OR s.member(x) IFF res.member(x)) AND \
    -- * res.size = self.SIZE + s.SIZE - intersect(s).SIZE  AND\
    -- * res=d_union.union(s,repr)
    -- * COMPLEXITY: \
    -- * SIZE__union(self.SIZE,s.SIZE) = $UNION__SET__I(T,KERNEL)::SIZE__union(self.SIZE,s.SIZE) \
