       repr := d_copy_set.copy_set(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- copy_set



  str:STR is
    res:=repr.str;
  end;


  choose_next(a:T):T is
    -- * METHOD:choose_next(a:T):T
    -- * DESCRIPTION: choose the smallest element which is larger than a \
    -- *-- *   if a is bigger than the largest element an exception is raised
    -- * PRE: EXISTS e:T: a < e
    -- * POST: member(res) AND FORALL e:T : (e > a AND member(e) IMPLIES res <= e) AND\
    -- * res=d_choose_next.choose_next(a,repr)
    -- * COMPLEXITY: \
    -- * SIZE__choose_next(self.SIZE,a.SIZE) = $CHOOSE_NEXT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__choose_next(self.SIZE,a.SIZE) \
    -- * SPACE__choose_next(self.SIZE,a.SIZE) = $CHOOSE_NEXT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__choose_next(self.SIZE,a.SIZE) \
    -- * TIME__choose_next(self.SIZE,a.SIZE) = $CHOOSE_NEXT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__choose_next(self.SIZE,a.SIZE)
    -- * REFERENCES:

    begin
       res := d_choose_next.choose_next(a,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- choose_next



  min:T is
    -- * METHOD:min:T
    -- * DESCRIPTION: choose minimum among all elements 
    -- * PRE: NOT empty
    -- * POST: FORALL a:T : member(a) IMPLIES res <= a AND member(res) AND\
    -- * res=d_min.min(repr)
    -- * COMPLEXITY: \
    -- * SIZE__min(self.SIZE) = $MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__min(self.SIZE) \
    -- * SPACE__min(self.SIZE) = $MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__min(self.SIZE) \
    -- * TIME__min(self.SIZE) = $MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__min(self.SIZE)
    -- * REFERENCES:

    begin
       res := d_min.min(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- min



  max:T is
    -- * METHOD:max:T
    -- * DESCRIPTION: choose maximum among all elements
    -- * PRE: true
    -- * POST: member(res) AND FORALL a:T : member(a) IMPLIES res>=a AND\
    -- * res=d_max.max(repr)
    -- * COMPLEXITY: \
    -- * SIZE__max(self.SIZE) = $MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__max(self.SIZE) \
    -- * SPACE__max(self.SIZE) = $MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__max(self.SIZE) \
    -- * TIME__max(self.SIZE) = $MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__max(self.SIZE)
    -- * REFERENCES:

    begin
       res := d_max.max(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- max



  choose_previous(a:T):T is
    -- * METHOD:choose_previous(a:T):T
    -- * DESCRIPTION: choose the largest element which is smaller than a \
    -- *-- *   if a is less than the minimum element an exception is raised
    -- * PRE: EXISTS e:T: e<a
    -- * POST: member(res) AND FORALL e:T : (e < a AND member(e) IMPLIES res >= e) AND\
    -- * res=d_choose_previous.choose_previous(a,repr)
    -- * COMPLEXITY: \
    -- * SIZE__choose_previous(self.SIZE,a.SIZE) = $CHOOSE_PREVIOUS__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__choose_previous(self.SIZE,a.SIZE) \
    -- * SPACE__choose_previous(self.SIZE,a.SIZE) = $CHOOSE_PREVIOUS__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__choose_previous(self.SIZE,a.SIZE) \
    -- * TIME__choose_previous(self.SIZE,a.SIZE) = $CHOOSE_PREVIOUS__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__choose_previous(self.SIZE,a.SIZE)
    -- * REFERENCES:

    begin
       res := d_choose_previous.choose_previous(a,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- choose_previous



  delete_min:SAME is
    -- * METHOD:delete_min:SAME
    -- * DESCRIPTION: delete the minimal element from set.
    -- * PRE: NOT self.empty
    -- * POST: res = self.delete(self.min) AND\
    -- * res=d_delete_min.delete_min(repr)
    -- * COMPLEXITY: \
    -- * SIZE__delete_min(self.SIZE) = $DELETE_MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__delete_min(self.SIZE) \
    -- * SPACE__delete_min(self.SIZE) = $DELETE_MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__delete_min(self.SIZE) \
    -- * TIME__delete_min(self.SIZE) = $DELETE_MIN__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__delete_min(self.SIZE)
    -- * REFERENCES:

    begin
       repr := d_delete_min.delete_min(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
    res := self;
  end; -- delete_min



  delete_max:SAME is
    -- * METHOD:delete_max:SAME
    -- * DESCRIPTION: delete the maximal element from set.
    -- * PRE: NOT self.empty
    -- * POST: res = self.delete(self.max) AND\
    -- * res=d_delete_max.delete_max(repr)
    -- * COMPLEXITY: \
    -- * SIZE__delete_max(self.SIZE) = $DELETE_MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__delete_max(self.SIZE) \
    -- * SPACE__delete_max(self.SIZE) = $DELETE_MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__delete_max(self.SIZE) \
    -- * TIME__delete_max(self.SIZE) = $DELETE_MAX__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__delete_max(self.SIZE)
    -- * REFERENCES:

    begin
       repr := d_delete_max.delete_max(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
    res := self;
  end; -- delete_max



  sort:$LIST(T) is
    -- * METHOD:sort:$LIST(T)
    -- * DESCRIPTION: sorting the elements in an ordered set
    -- * PRE: true
    -- * POST: res.size = size AND \
    -- *    FORALL 0<=i<size: member(res.next^i.element) AND \
    -- *         (i < size -1 IMPLIES  res.next^i.element < res.next^(i+1).element) AND\
    -- * res=d_sort.sort(repr)
    -- * COMPLEXITY: \
    -- * SIZE__sort(self.SIZE) = $SORT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__sort(self.SIZE) \
    -- * SPACE__sort(self.SIZE) = $SORT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__sort(self.SIZE) \
    -- * TIME__sort(self.SIZE) = $SORT__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__sort(self.SIZE)
    -- * REFERENCES:

    begin
       res := d_sort.sort(repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- sort



  stream from_to(const lower:T;const upper:T):T is
    -- * METHOD:stream from_to(const lower:T;const upper:T):T
    -- * DESCRIPTION: stream yielding the elements between lower and upper \
    -- *-- * in order
    -- * PRE: true
    -- * POST: (from_to.terminated IFF res[i]=max OR empty OR \
    -- * |                             choose_next(res[i])>upper AND res[i-multiplicity(res[i])+1]=res[i]) AND\
    -- *       (member(lower) IMPLIES res[1]=lower) AND \
    -- *       (NOT member(lower) IMPLIES res[1]=choose_next(lower)) AND \
    -- *       (FORALL 0<=j<multiplicity(res[i-1]): res[i-1-j]=res[i-1] IMPLIES res[i]=choose_next(res[i-1]) AND \
    -- *       (multiplicity(res[i-1])>i OR res[i-multiplicity(res[i-1])]/=res[i-1] IMPLIES res[i]=res[i-1]) AND \
    -- *       self[i]=self AND\
    -- * FORALL i:INT: i>=1 IMPLIES res[i]=d_from_to.[from_to!(lower,upper,repr)]^i
    -- * COMPLEXITY: \
    -- * SIZE__from_to(self.SIZE,lower.SIZE,upper.SIZE,k) = $FROM_TO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__from_to(self.SIZE,lower.SIZE,upper.SIZE,k) \
    -- * SPACE__from_to(self.SIZE,lower.SIZE,upper.SIZE,k) = $FROM_TO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__from_to(self.SIZE,lower.SIZE,upper.SIZE,k) \
    -- * TIME__from_to(self.SIZE,lower.SIZE,upper.SIZE,k) = $FROM_TO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__from_to(self.SIZE,lower.SIZE,upper.SIZE,k)
    -- * REFERENCES:

    begin
      loop
         res := d_from_to.from_to!(lower,upper,repr);
         resume;
      end;
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- from_to



  stream from_downto(const upper:T;const lower:T):T is
    -- * METHOD:stream from_downto(const upper:T;const lower:T):T
    -- * DESCRIPTION: stream yielding the elements between upper and lower \
    -- *-- * in reverse order
    -- * PRE: true
    -- * POST: (from_downto.terminated IFF res[i]=min OR empty OR \
    -- * |                                  choose_previous(res[i])<lower AND res[i-multiplicity(res[i]+1)]=res[i]) AND\
    -- * FORALL i:INT: i>=1 IMPLIES res[i]=d_from_downto.[from_downto!(upper,lower,repr)]^i
    -- *-- * AND\
    -- *-- *       (member(upper) IMPLIES res[1]=upper) AND \
    -- *-- *       (NOT member(upper) IMPLIES res[1]=choose_previous(upper)) AND \
    -- *-- *       (FORALL 0<=j<multiplicity(res[i-1]): res[i-1-j]=res[i-1] IMPLIES res[i]=choose_previous(res[i-1]) AND \
    -- *-- *       (multiplicity(res[i-1])>i OR res[i-multiplicity(res[i-1])]/=res[i-1] IMPLIES res[i]=res[i-1]) AND \
    -- *-- *       self[i]=self
    -- * COMPLEXITY: \
    -- * SIZE__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k) = $FROM_DOWNTO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SIZE__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k) \
    -- * SPACE__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k) = $FROM_DOWNTO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::SPACE__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k) \
    -- * TIME__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k) = $FROM_DOWNTO__ORDERED_MULTISET__I(T,ORDER,KERNEL)::TIME__from_downto(self.SIZE,upper.SIZE,lower.SIZE,k)
    -- * REFERENCES:

    begin
      loop
         res := d_from_downto.from_downto!(upper,lower,repr);
         resume;
      end;
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_MIN then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_NEXT then msg.raise;
      when EXCEPTION__ORDERED_MULTISET_PREVIOUS then msg.raise;
      when EXCEPTION__ORDERED__MULTISET__MAX then msg.raise;
    end;
  end; -- from_downto



end; -- FINITE_ORDERED_SET__I(T1,T<FINITE_ORDERED(T1),ORDER<ORDER_RELATION(T),KERNEL<FINITE_ORDERED_SET(T1,T,ORDER))




