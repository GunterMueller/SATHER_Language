      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- union



  intersect(s:$SET(T)):SAME is
    -- * METHOD:intersect(s:$SET(T)):SAME
    -- * DESCRIPTION: abstract method for intersection of self and s
    -- * PRE:   true
    -- * POST:  (FORALL x:T: member(x) AND s.member(x) IFF res.member(x) AND \
    -- * res.size = sum(multiplicity(x)*s.multiplicity(x); member(x)) AND\
    -- * res=d_intersect.intersect(s,repr)
    -- * COMPLEXITY: \
    -- * SIZE__intersect(self.SIZE,s.SIZE) = $INTERSECT__SET__I(T,KERNEL)::SIZE__intersect(self.SIZE,s.SIZE) \
    -- * SPACE__intersect(self.SIZE,s.SIZE) = $INTERSECT__SET__I(T,KERNEL)::SPACE__intersect(self.SIZE,s.SIZE) \
    -- * TIME__intersect(self.SIZE,s.SIZE) = $INTERSECT__SET__I(T,KERNEL)::TIME__intersect(self.SIZE,s.SIZE)
    -- * REFERENCES:

    begin
       repr := d_intersect.intersect(s,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- intersect



  diff(s:$SET(T)):SAME is
    -- * METHOD:diff(s:$SET(T)):SAME
    -- * DESCRIPTION: abstract method for set difference of self and s
    -- * PRE:   	true
    -- * POST:  (FORALL x:T: res.member(x) IFF member(x) AND NOT s.member(x)) AND \
    -- * res.size = sum(x:T,res.multiplicity(x)) AND\
    -- * res=d_diff.diff(s,repr)
    -- * COMPLEXITY: \
    -- * SIZE__diff(self.SIZE,s.SIZE) = $DIFF__SET__I(T,KERNEL)::SIZE__diff(self.SIZE,s.SIZE) \
    -- * SPACE__diff(self.SIZE,s.SIZE) = $DIFF__SET__I(T,KERNEL)::SPACE__diff(self.SIZE,s.SIZE) \
    -- * TIME__diff(self.SIZE,s.SIZE) = $DIFF__SET__I(T,KERNEL)::TIME__diff(self.SIZE,s.SIZE)
    -- * REFERENCES:

    begin
       repr := d_diff.diff(s,repr);
    except msg
      when EXCEPTION__MULTISET then msg.raise;
      when EXCEPTION__SET_ADD then msg.raise;
      when EXCEPTION__SET_DISJOINT_UNION then msg.raise;
    end;
    res := self;
  end; -- diff



  subset(s:$SET(T)):BOOL is
    -- * METHOD:subset(s:$SET(T)):BOOL
    -- * DESCRIPTION: true iff self is subset of s
    -- * PRE: true
    -- * POST: res = FORALL x:T: member(x) IMPLIES s.member(x) AND\
    -- * res=d_subset.subset(s,repr)
    -- * COMPLEXITY: \
    -- * SIZE__subset(self.SIZE,s.SIZE) = $SUBSET__SET__I(T,KERNEL)::SIZE__subset(self.SIZE,s.SIZE) \
