abstract class BOUNDED_PARTIAL_SET(K,T1,T<PARTIAL(K,T1)) is
   -- * CLASS: BOUNDED_PARTIAL_SET(K,T1,T<PARTIAL(K,T1))
   -- * DESCRIPTION: abstract class defining Sets with limited number of elements \
   -- *              partial key access
   -- * SUBCLASS OF: BOUNDED_SET(T)
   -- * SPECIALIZATION OF: PARTIAL_SET(K,T1,T) BOUNDED_PARTIAL_MULTISET(K,T1,T)
   -- * IMPLEMENTATION OF: 
   -- * EXCEPTIONS: EXCEPTION__BOUNDED_MULTISET_INS EXCEPTION__BOUNDED_MULTISET_UNION \
   -- * EXCEPTION__MULTISET EXCEPTION__SET_ADD EXCEPTION__SET_DISJOINT_UNION \
   -- * EXCEPTION__PARTIAL_MULTISET_LOOKUP
   -- * INVARIANT: BOUNDED_SET(T)::Inv AND PARTIAL_SET(K,T1,T)::Inv
   -- * REPRESENTATION:
   -- * COMPLEXITY: \
   -- *     static      SIZE = size; \
   -- *                 ##.init.MAXSIZE = 0 AND \
   -- *                 MAXSIZE = max(choose.SIZE,delete(choose).MAXSIZE)
   -- * REFERENCES: [Aho, Hopcroft, Ullman: "The Design and Analysis \
   -- *               of Computer Algorithms", Addison-Wesley, 1974]
   -- * ATTRIBUTES: size:INT \
   -- *     max_size:INT 

   include PARTIAL_SET(K,T1,T);
   subtype of BOUNDED_SET(T);

   
end;





--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 

class TEST__BOUNDED_PARTIAL_SET is
-- * CLASS: TEST__BOUNDED_SET
-- * DESCRIPTION: 
-- * SUBCLASS OF: 
-- * SPECIALIZATION OF: 
-- * IMPLEMENTATION OF: 
-- * EXCEPTIONS: 
-- * INVARIANT: 
-- * COMPLEXITY: 
-- * REFERENCES: 


   main is
      a:$BOUNDED_SET(PARTIAL_INT):=# BOUNDED_PARTIAL_SET(INT,INT,PARTIAL_INT); -- {max_size:=10};
      ERR::s("creation of abstract class succeeded.\n");
   end;

end; -- class TEST__BOUNDED_SET

